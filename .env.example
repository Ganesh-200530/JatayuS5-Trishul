# AutoAuthAgent — Environment Variables
# Copy to .env and fill in values

# Database
DATABASE_URL=postgresql+asyncpg://autoauth:autoauth@localhost:5432/autoauth

# Gemini
GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.0-flash

# JWT Auth
SECRET_KEY=change-me-to-a-random-secret-key-at-least-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# FHIR Server (HAPI FHIR or EHR sandbox)
FHIR_BASE_URL=http://localhost:8080/fhir
FHIR_AUTH_TOKEN=

# App
APP_ENV=development
LOG_LEVEL=INFO
CONFIDENCE_THRESHOLD=0.95
